<?jelly escape-by-default='true'?>
<j:jelly xmlns:j="jelly:core" xmlns:f="/lib/form" xmlns:c="/lib/credentials">

  <f:radioBlock name="mode" value="local" title="Local (offline) — no CXRay server or credentials"
                checked="${instance.mode != 'api'}" inline="true">
    <f:entry title="MCP server config" field="configPath"
             description="Workspace path to mcp.json / server.json — transport &amp; identity posture. Optional.">
      <f:textbox/>
    </f:entry>
    <f:entry title="Tool manifest" field="manifestPath"
             description="Workspace path to a tools/list manifest — tool-poisoning scan. Optional.">
      <f:textbox/>
    </f:entry>
    <f:entry title="Model file" field="modelFilePath"
             description="Workspace path to an Ollama Modelfile / model-server config — supply-chain &amp; exposure scan. Optional.">
      <f:textbox/>
    </f:entry>
    <f:entry title="Ingested content" field="contentPath"
             description="Workspace path to agent-ingested data (retrieved doc / tool output) — indirect prompt-injection scan (OWASP-LLM01 / ASI01). Optional.">
      <f:textbox/>
    </f:entry>
    <f:entry title="MCP server id" field="mcpServerId"
             description="Identity of the server behind the tool manifest — checked against the mcpAllow allowlist in .cxray/policy.json (ASI03). Optional.">
      <f:textbox/>
    </f:entry>
  </f:radioBlock>

  <f:radioBlock name="mode" value="api" title="CXRay API — gate an image scanned in CXRay"
                checked="${instance.mode == 'api'}" inline="true">
    <f:entry title="Image ID" field="imageId"
             description="Gate an image already scanned in CXRay. Leave blank to scan-and-gate a registry image below.">
      <f:textbox/>
    </f:entry>

    <f:section title="…or scan a registry image (scan-and-gate)">
      <f:entry title="Registry / repo" field="repo"
               description="Registry host or repository namespace (optional).">
        <f:textbox/>
      </f:entry>
      <f:entry title="Image" field="image"
               description="Image name to pull &amp; scan. Set this (instead of Image ID) to scan-and-gate.">
        <f:textbox/>
      </f:entry>
      <f:entry title="Tag" field="tag" description="Image tag (default 'latest').">
        <f:textbox default="latest"/>
      </f:entry>
      <f:entry title="Registry credentials" field="registryCredentialsId"
               description="Username/password for a private registry pull (optional).">
        <c:select/>
      </f:entry>
      <f:entry title="Scan timeout (s)" field="pollTimeoutSec" description="Fail if the scan doesn't finish in time.">
        <f:number default="600"/>
      </f:entry>
      <f:entry title="Poll interval (s)" field="pollIntervalSec" description="How often to poll scan status (min 2).">
        <f:number default="10"/>
      </f:entry>
    </f:section>

    <f:entry title="CXRay credentials" field="credentialsId"
             description="Username/password credential: access key (username) + secret key (password). IP-bound — register the agent's egress IP once.">
      <c:select/>
    </f:entry>
    <f:entry title="Gates" field="gates"
             description="Comma-separated subset of: cve, license, secrets, ai">
      <f:textbox default="cve,license,secrets,ai"/>
    </f:entry>
    <f:entry title="Max CVSS" field="maxCvss"
             description="CVE gate fails on any CVSS ≥ this value.">
      <f:number default="9.0" step="0.1"/>
    </f:entry>
    <f:entry title="Fail on KEV" field="failOnKev"
             description="CVE gate fails on any CISA-KEV (actively exploited) CVE.">
      <f:checkbox default="true"/>
    </f:entry>
  </f:radioBlock>

  <f:entry title="Fail on" field="failOn"
           description="Block the build on FAIL only (default), or also on REVIEW.">
    <f:select/>
  </f:entry>
  <f:entry title="Attestation path" field="attestationPath"
           description="Optional — workspace path to write an in-toto/SLSA gate attestation (verdict + inputs + policy digest). Sign it with cosign/in-toto in a later step. e.g. cxray-attestation.json">
    <f:textbox/>
  </f:entry>
  <f:entry title="SARIF path" field="sarifPath"
           description="Optional — workspace path to write a SARIF 2.1.0 report (upload to GitHub code scanning or archive). e.g. cxray.sarif">
    <f:textbox/>
  </f:entry>
  <f:entry title="Dry run" field="dryRun"
           description="Simulate: run the gate and write the report/attestation/SARIF, log what WOULD block, but never fail the build. Adoption/rollout lever.">
    <f:checkbox/>
  </f:entry>
</j:jelly>
